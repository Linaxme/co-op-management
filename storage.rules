rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /cooperatives/{coopId}/members/{memberUuid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /cooperatives/{coopId}/branding/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
